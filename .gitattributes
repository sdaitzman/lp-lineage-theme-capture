# Captured production HTML, CSS, and source maps are reference material —
# they're large, machine-generated by the live LP Plone backend, and
# noisy to diff. Mark them as linguist-generated so GitHub / Gitup /
# git-diff suppress per-file diffs and language stats.

captured-themes/**/html/*.html       -diff linguist-generated=true
captured-themes/**/css/*.css         -diff linguist-generated=true
captured-themes/**/css/*.css.map     -diff linguist-generated=true

# PNG/JPG/SVG screenshots and image assets are already binary, but be
# explicit so Git treats them as such cross-platform.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.svg       -diff
